{
  "name": "@telepat/ansie",
  "version": "0.1.1",
  "description": "Terminal image rendering and ANSI utility toolkit with automatic capability detection.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "ansie": "dist/src/bin.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "keywords": [
    "ansi",
    "ascii",
    "terminal",
    "cli",
    "image",
    "render"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/telepat-io/ansie.git"
  },
  "bugs": {
    "url": "https://github.com/telepat-io/ansie/issues"
  },
  "homepage": "https://github.com/telepat-io/ansie",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
